{
  "expo": {
    "name": "Virem",
    "slug": "virem",
    "version": "1.0.0",
    "description": "App de citas médicas con médicos, pacientes, chat, videollamadas y pagos",
    "primaryColor": "#007bff",
    "orientation": "portrait",
    "icon": "./assets/imagenes/descarga.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/imagenes/descarga.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bitcode": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/imagenes/descarga.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ],
      "package": "com.anonymous.virem"
    },
    "web": {
      "favicon": "./assets/imagenes/descarga.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-secure-store",
      [
        "@config-plugins/react-native-webrtc",
        {
          "appleTeamId": "YOUR_TEAM_ID",
          "cameraPermission": "VIREM necesita acceso a la cámara para las videollamadas.",
          "microphonePermission": "VIREM necesita acceso al micrófono para las videollamadas."
        }
      ]
    ]
  }
}
