{
  "name": "virem",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "start:web": "cross-env EXPO_PUBLIC_BACKEND_URL=http://localhost:3000 expo start --web -c",
    "start:mobile": "expo start -c",
    "start:mobile:remote": "cross-env EXPO_PUBLIC_BACKEND_URL=https://virem-backend.onrender.com expo start -c",
    "build": "npx expo export --platform web --output-dir dist-web --clear"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@babel/highlight": "^7.25.9",
    "@config-plugins/react-native-webrtc": "^14.0.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.27",
    "@react-navigation/native-stack": "^7.9.1",
    "expo": "~54.0.27",
    "expo-face-detector": "^13.0.2",
    "expo-font": "~14.0.9",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "^55.0.15",
    "expo-router": "~6.0.22",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/dom-mediacapture-record": "^1.0.22",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/react-native": "^0.72.8",
    "@types/react-native-vector-icons": "^6.4.18",
    "babel-preset-expo": "~54.0.10",
    "cross-env": "^10.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
